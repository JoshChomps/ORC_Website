---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - Page Not Found">
	<Header />
	
	<main class="not-found">
		<h2 class="error-code">404</h2>
		<h3 class="error-msg">Mission Aborted: Page Not Found</h3>
		<p class="error-detail">Coordinates Unknown</p>
		<a href={import.meta.env.BASE_URL} class="back-btn">Back to Mission Control</a>
	</main>

	<Footer />
</Layout>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 70vh;
		margin-top: 80px;
		text-align: center;
		padding: 0 20px;
	}

	.error-code {
		font-family: var(--font-title);
		font-size: clamp(4rem, 15vw, 10rem);
		color: var(--color-nebula);
		margin: 0;
		line-height: 1;
		opacity: 0.5;
	}

	.error-msg {
		font-family: var(--font-title);
		font-size: clamp(1.5rem, 4vw, 3rem);
		color: var(--color-nebula);
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	.error-detail {
		font-family: var(--font-header);
		font-size: clamp(1rem, 2vw, 1.5rem);
		color: var(--color-nebula);
		text-transform: uppercase;
		letter-spacing: 4px;
	}

	.back-btn {
		margin-top: 3rem;
		color: var(--color-star);
		text-decoration: none;
		font-family: var(--font-header);
		font-size: 1.1rem;
		border: 1px solid var(--glass-border);
		padding: 12px 30px;
		border-radius: 40px;
		background: var(--glass);
		transition: var(--transition);
		text-transform: uppercase;
	}

	.back-btn:hover {
		border-color: var(--color-nebula);
		box-shadow: var(--glow-nebula);
		transform: translateY(-3px);
	}
</style>
