---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import gearLogo from '../assets/gear-logo.png';
import groupPhoto from '../assets/group_photo.jpg';
import groupPhoto2 from '../assets/IMG_1324.jpg';

const groups = [
    {
        title: "The Rover",
        description: "Technical shots and field tests of our latest rover designs.",
        items: [
            { type: 'photo', label: 'Rover Logo Design', src: gearLogo },
            { type: 'photo', label: 'Team Collaboration', src: groupPhoto }
        ]
    },
    {
        title: "Team & Events",
        description: "Photos from our workshops and team bonding sessions.",
        items: [
            { type: 'photo', label: 'Field Testing', src: groupPhoto2 }
        ]
    }
];
---

<Layout title="Gallery - Okanagan Rovercraft">
	<div class="gallery-page">
		<Header />

		<main>
			<section class="gallery-hero">
				<h1 class="gallery-title">Photos & Videos</h1>
				<p class="gallery-subtitle">A collection of shots from the workshop and the field.</p>
			</section>

			<section class="gallery-content">
                {groups.map(g => (
                    <div class="gallery-group">
                        <div class="group-header">
                            <h2 class="group-title">{g.title}</h2>
                            <p class="group-description">{g.description}</p>
                        </div>
                        
                        <div class="gallery-grid">
                            {g.items.map(i => (
                                <div class="gallery-card" data-zoomable>
                                    <div class="card-media">
                                        <Image src={i.src} alt={i.label} width={800} quality={100} />
                                        <div class="overlay">Expand View</div>
                                    </div>
                                    <div class="card-info">
                                        <span class="item-type">{i.type}</span>
                                        <h3 class="item-label">{i.label}</h3>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
			</section>

			<Footer />
		</main>
	</div>
</Layout>

<style>
    .gallery-page {
        min-height: 100vh;
    }

    .gallery-hero {
        padding: 180px 10% 80px;
        text-align: center;
    }

    .gallery-title {
        font-family: var(--font-title);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        color: var(--color-nebula);
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .gallery-subtitle {
        font-family: var(--font-body);
        color: var(--color-stardust);
        max-width: 600px;
        margin: 0 auto;
        font-size: 1.1rem;
    }

    .gallery-content {
        padding: 0 10% 120px;
    }

    .gallery-group {
        margin-bottom: 80px;
    }

    .group-header {
        margin-bottom: 40px;
        border-left: 4px solid var(--color-nebula);
        padding-left: 20px;
    }

    .group-title {
        font-family: var(--font-title);
        font-size: 2rem;
        color: var(--color-star);
        margin-bottom: 10px;
    }

    .group-description {
        color: var(--color-stardust);
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 30px;
    }

    .gallery-card {
        background: var(--glass);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        overflow: hidden;
        transition: var(--transition);
        backdrop-filter: blur(10px);
    }

    .gallery-card:hover {
        transform: translateY(-10px);
        border-color: var(--color-nebula);
        box-shadow: var(--glow-nebula);
    }

    .card-media {
        aspect-ratio: 16/9;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        font-size: 3rem;
        color: var(--color-stardust);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-header);
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        opacity: 0;
        transition: var(--transition);
    }

    .gallery-card:hover .overlay {
        opacity: 1;
    }

    .card-info {
        padding: 20px;
    }

    .item-type {
        font-family: var(--font-header);
        color: var(--color-nebula);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .item-label {
        font-family: var(--font-body);
        color: var(--color-star);
        font-size: 1.2rem;
        margin-top: 5px;
    }

    @media (max-width: 768px) {
        .gallery-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
