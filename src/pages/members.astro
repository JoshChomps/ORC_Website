---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const execs = [
  { role: 'President', name: 'Coming Soon' },
  { role: 'Vice President', name: 'Coming Soon' },
  { role: 'VP Finance', name: 'Coming Soon' },
  { role: 'VP Operations', name: 'Coming Soon' },
];

const teamData = [
  {
    name: 'Functions',
    members: [
      { role: 'Team Lead', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
    ],
  },
  {
    name: 'Controls',
    members: [
      { role: 'Team Lead', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
    ],
  },
  {
    name: 'Programming',
    members: [
      { role: 'Team Lead', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
    ],
  },
  {
    name: 'Administration',
    members: [
      { role: 'Team Lead', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
      { role: 'Member', name: 'Coming Soon' },
    ],
  },
];
---

<Layout title="Members - Okanagan Rovercraft">
  <Header />

  <main class="members-page">

    <section class="members-hero">
      <h1 class="members-title">Our Team</h1>
      <p class="members-subtitle">
        Meet the brilliant minds behind Okanagan Rovercraft. We are a multidisciplinary team of students united by a passion for robotics and exploration.
      </p>
    </section>

    <section class="team-section">
      <div class="section-label">
        <span class="label-line"></span>
        <h2 class="section-title">Executives</h2>
        <span class="label-line"></span>
      </div>
      <div class="exec-grid">
        {execs.map(exec => (
          <div class="profile-card exec-card">
            <div class="profile-avatar">
              <div class="avatar-placeholder">
                <svg viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
                  <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </svg>
              </div>
            </div>
            <div class="profile-info">
              <p class="profile-role">{exec.role}</p>
              <h3 class="profile-name">{exec.name}</h3>
            </div>
          </div>
        ))}
      </div>
    </section>

    {teamData.map(team => (
      <section class="team-section">
        <div class="section-label">
          <span class="label-line" style="background: var(--color-nebula)"></span>
          <h2 class="section-title" style="color: var(--color-nebula)">{team.name}</h2>
          <span class="label-line" style="background: var(--color-nebula)"></span>
        </div>
        <div class="team-grid">
          {team.members.map(member => (
            <div class="profile-card">
              <div class="profile-avatar">
                <div class="avatar-placeholder">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
                    <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                  </svg>
                </div>
              </div>
              <div class="profile-info">
                <p class="profile-role">{member.role}</p>
                <h3 class="profile-name">{member.name}</h3>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

  </main>

  <Footer />
</Layout>

<style>
  .members-page {
    margin-top: 120px;
    padding-bottom: 120px;
  }
  .members-hero {
    text-align: center;
    padding: 60px 10% 80px;
  }
  .members-title {
    font-family: var(--font-title);
    font-size: clamp(3rem, 8vw, 5rem);
    color: var(--color-nebula);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }
  .members-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--color-stardust);
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.8;
  }
  .team-section {
    padding: 60px 8% 20px;
  }
  .section-label {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .section-title {
    font-family: var(--font-title);
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-star);
    white-space: nowrap;
    margin: 0;
  }
  .label-line {
    flex: 1;
    height: 1px;
    background: var(--glass-border);
    display: block;
  }
  .exec-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }
  .exec-card {
    width: 220px;
  }
  .exec-card .avatar-placeholder {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: rgba(0, 209, 255, 0.08);
    border: 2px solid rgba(0, 209, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 209, 255, 0.5);
    margin: 0 auto 16px;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
  }
  .profile-card {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 28px 20px 24px;
    text-align: center;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    backdrop-filter: blur(10px);
  }
  .profile-card:hover {
    transform: translateY(-6px);
    border-color: var(--team-color, var(--color-nebula));
    box-shadow: 0 0 20px color-mix(in srgb, var(--team-color, var(--color-nebula)) 30%, transparent);
  }
  .avatar-placeholder {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.2);
    margin: 0 auto 14px;
    transition: border-color 0.25s ease;
  }
  .profile-card:hover .avatar-placeholder {
    border-color: var(--team-color, var(--color-nebula));
  }
  .profile-role {
    font-family: var(--font-header);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--team-color, var(--color-nebula));
    margin: 0 0 6px;
  }
  .profile-name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-stardust);
    margin: 0;
    font-weight: 400;
  }
  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }
    .exec-card {
      width: 160px;
    }
  }
</style>
