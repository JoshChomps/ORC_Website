---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import { Image } from 'astro:assets';
import groupPhoto3 from '../assets/IMG_1259.jpg';
import altarLogo from '../assets/sponsors/altar.png';
import polymakerLogo from '../assets/sponsors/polymaker.png';
import stepperLogo from '../assets/sponsors/stepperonline.jpg';
import '../styles/sponsors.css';
---

<Layout title="Sponsors - Okanagan Rovercraft">
	<Header />
	
	<main style="margin-top: 80px;">
		<section class="content_section sponsor-hero">
			<div class="content">
				<div class="sponsor-hero-text">
					<h2>Our sponsors help us build both rovers and careers.</h2>
					<p class="content_text">
						Contributions of materials, expertise, and funding allow our team to prototype, test, and compete at a world-class level. 
						We're incredibly grateful to the organizations that invest in our growth and the future of student-led engineering.
					</p>
				</div>
				<div class="image-frame">
					<Image src={groupPhoto3} alt="Team at Competition" loading="eager" width={1200} quality="high" />
				</div>
			</div>
		</section>

		<div class="sponsor-container">
			<h2>Current Partners</h2>
			<p>Thank you for supporting Okanagan Rover Craft.</p>
			<div class="sponsor-list">
				<div class="sponsor-card">
					<div class="sponsor-logo"><Image src={altarLogo} alt="Altar Metal Fab Co." loading="lazy" /></div>
					<p>Altar Metal Fab Co.</p>
				</div>
				<div class="sponsor-card">
					<div class="sponsor-logo"><Image src={polymakerLogo} alt="Polymaker" loading="lazy" /></div>
					<p>Polymaker</p>
				</div>
				<div class="sponsor-card">
					<div class="sponsor-logo"><Image src={stepperLogo} alt="Stepper Online" loading="lazy" /></div>
					<p>Stepper Online</p>
				</div>
			</div>
		</div>

		<section class="content_section">
			<div class="content">
				<h2>How to get involved</h2>
				<div class="content-flex">
					<p class="content_text">
						We are always looking for passionate partners to join our mission. 
						Sponsoring our team provides your organization with brand visibility while 
						directly supporting top student talent in STEM. 
						If you're interested in collaborating, check out our package below or reach out to us at 
						outreach@okanaganrovercraft.ca.
					</p>
					
					<div class="pdf-button-container" style="margin-top:-80px">
						<embed id="sponsorship-pdf" src={import.meta.env.BASE_URL + "ORC SPONSORSHIP PACKAGE 2026 - 4 (compressed V3).pdf"} type="application/pdf"/>
						<a href={import.meta.env.BASE_URL + "ORC SPONSORSHIP PACKAGE 2026 - 4 (compressed V3).pdf"} download class="SP_button">
							&nbsp;Download Our Sponsorship Package Here
						<span class="arrow">→</span>
					</a>
					</div>
				</div>
			</div>
		</section>

		<section class="contact-section">
			<ContactForm />
		</section>
	</main>

	<Footer />
</Layout>
