---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import groupPhoto2 from '../assets/IMG_1324.jpg';
---

<Layout title="About Us - Okanagan Rovercraft">
	<Header />
	
	<main style="margin-top: 80px;">
		<section class="content_section about-hero">
			<div class="content">
				<div class="about-hero-text">
					<h1 class="content_title">About the Team</h1>
					<p class="content_text">
						Okanagan Rover Craft started as a shared project between a few classmates and officially launched in late 2025. 
						We're a team of students focused on designing and building a rover for the 
						Canadian International Robotics Challenge (CIRC). For us, it's more than just a competition, it's about 
						professional growth, practical engineering, and building something cool together. 
						We're always looking for new members, so feel free to reach out if you're interested in joining.
					</p>
				</div>
				<div class="image-frame">
					<Image src={groupPhoto2} alt="Team Photo" loading="eager" width={1200} quality="high" />
				</div>
			</div>
		</section>

		<section class="content_section" id="get_involved" style="min-height: auto; padding: 60px 0;">
			<div class="content">
				<h2>How to get involved</h2>
				<p class="content_text">
					We're always looking for passionate collaborators and partners to support our mission. 
					By sponsoring Okanagan Rover Craft, you're directly helping us with prototyping, testing, 
					and competition costs, while connecting with top student talent at UBCO. 
					If your organization is interested in supporting our work, we'd love to chat.
				</p>
				<button class="learn-more" onclick={`window.location.href='${import.meta.env.BASE_URL + "sponsors"}'`}>
					Sponsorship Info
					<span class="arrow">→</span>
				</button>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
