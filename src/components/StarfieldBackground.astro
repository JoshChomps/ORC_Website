---
---
<canvas id="star-canvas"></canvas>

<style is:global>
  #star-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
  body { background: #050505; }
</style>

<script>
import * as THREE from 'three';
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

const canvas = document.getElementById('star-canvas') as HTMLCanvasElement;
const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, alpha: false });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setClearColor(0x050505, 1);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 2000);
camera.position.z = 400;

const starVert = `
  attribute float aOpacity;
  attribute float aFreq;
  attribute float aOff;
  attribute float aSize;

  varying float vOpacity;
  varying float vFreq;
  varying float vOff;

  void main() {
    vOpacity = aOpacity;
    vFreq = aFreq;
    vOff = aOff;
    vec4 mvPos = modelViewMatrix * vec4(position, 1.0);
    gl_PointSize = aSize * (300.0 / -mvPos.z);
    gl_PointSize = clamp(gl_PointSize, 0.5, 3.5);
    gl_Position = projectionMatrix * mvPos;
  }
`;

const starFrag = `
  uniform float uTime;
  varying float vOpacity;
  varying float vFreq;
  varying float vOff;

  void main() {
    vec2 uv = gl_PointCoord - vec2(0.5);
    if (length(uv) > 0.5) discard;
    float edge = 1.0 - smoothstep(0.3, 0.5, length(uv));
    float twinkle = 0.5 + 0.5 * sin(uTime * vFreq + vOff);
    gl_FragColor = vec4(1.0, 1.0, 1.0, vOpacity * twinkle * edge);
  }
`;

const wispVert = `
  attribute float aSize;
  void main() {
    vec4 mvPos = modelViewMatrix * vec4(position, 1.0);
    gl_PointSize = aSize * (400.0 / -mvPos.z);
    gl_PointSize = clamp(gl_PointSize, 10.0, 80.0);
    gl_Position = projectionMatrix * mvPos;
  }
`;

const wispFrag = `
  uniform vec3 uColor;
  uniform float uAlpha;
  void main() {
    vec2 uv = gl_PointCoord - vec2(0.5);
    float dist = length(uv);
    if (dist > 0.5) discard;
    gl_FragColor = vec4(uColor, uAlpha * pow(1.0 - dist * 2.0, 3.0));
  }
`;

const planetVert = `
  varying vec2 vUv;
  varying vec3 vNorm;
  void main() {
    vUv = uv;
    vNorm = normalize(normalMatrix * normal);
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
  }
`;

const planetFrag = `
  uniform vec3 c1; uniform vec3 c2; uniform vec3 c3;
  uniform float time;
  varying vec2 vUv; varying vec3 vNorm;

  float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453); }
  float noise(vec2 p) {
    vec2 i = floor(p); vec2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    return mix(mix(hash(i), hash(i + vec2(1,0)), f.x), mix(hash(i + vec2(0,1)), hash(i + vec2(1,1)), f.x), f.y);
  }

  void main() {
    float n1 = noise(vec2(vUv.x * 4.0, vUv.y * 3.0 + time * 0.02));
    float n2 = noise(vec2(vUv.x * 6.0 + 1.3, vUv.y * 5.0 - time * 0.015));
    vec3 col = mix(mix(c1, c2, n1), c3, n2 * 0.4);
    float limb = pow(max(dot(vNorm, vec3(0,0,1)), 0.0), 0.5);
    col *= (0.4 + 0.6 * limb);
    float spec = pow(max(dot(vNorm, normalize(vec3(-0.5, 0.8, 0.6))), 0.0), 8.0) * 0.3;
    gl_FragColor = vec4(col + spec, 1.0);
  }
`;

const atmFrag = `
  uniform vec3 atmCol;
  varying vec3 vNorm;
  void main() {
    float glow = pow(1.0 - abs(dot(vNorm, vec3(0,0,1))), 2.5);
    gl_FragColor = vec4(atmCol, glow * 0.5);
  }
`;

const count = 6000;
const pos = new Float32Array(count * 3);
const ops = new Float32Array(count);
const freqs = new Float32Array(count);
const offs = new Float32Array(count);
const sizes = new Float32Array(count);

for (let i = 0; i < count; i++) {
  const i3 = i * 3;
  const theta = Math.random() * Math.PI * 2;
  const phi = Math.acos(2 * Math.random() - 1);
  const r = 300 + Math.random() * 500;
  pos[i3] = r * Math.sin(phi) * Math.cos(theta);
  pos[i3 + 1] = r * Math.sin(phi) * Math.sin(theta);
  pos[i3 + 2] = r * Math.cos(phi);
  ops[i] = 0.3 + Math.random() * 0.7;
  freqs[i] = 0.4 + Math.random() * 2.6;
  offs[i] = Math.random() * Math.PI * 2;
  sizes[i] = 0.8 + Math.random() * 2.0;
}

const geo = new THREE.BufferGeometry();
geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
geo.setAttribute('aOpacity', new THREE.BufferAttribute(ops, 1));
geo.setAttribute('aFreq', new THREE.BufferAttribute(freqs, 1));
geo.setAttribute('aOff', new THREE.BufferAttribute(offs, 1));
geo.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));

const uniforms = { uTime: { value: 0 } };
const stars = new THREE.Points(geo, new THREE.ShaderMaterial({
  uniforms, vertexShader: starVert, fragmentShader: starFrag,
  transparent: true, depthWrite: false, blending: THREE.AdditiveBlending
}));
scene.add(stars);

const wCount = 400;
const wPos = new Float32Array(wCount * 3);
const wSizes = new Float32Array(wCount);
for (let i = 0; i < wCount; i++) {
  const i3 = i * 3;
  const side = Math.random() > 0.5 ? 1 : -1;
  wPos[i3] = side * (150 + Math.random() * 300);
  wPos[i3+1] = (Math.random() - 0.5) * 300;
  wPos[i3+2] = -200 - Math.random() * 400;
  wSizes[i] = 20 + Math.random() * 60;
}
const wGeo = new THREE.BufferGeometry();
wGeo.setAttribute('position', new THREE.BufferAttribute(wPos, 3));
wGeo.setAttribute('aSize', new THREE.BufferAttribute(wSizes, 1));

const addWisp = (c, a) => scene.add(new THREE.Points(wGeo, new THREE.ShaderMaterial({
  uniforms: { uColor: { value: new THREE.Color(c) }, uAlpha: { value: a } },
  vertexShader: wispVert, fragmentShader: wispFrag,
  transparent: true, depthWrite: false, blending: THREE.AdditiveBlending
})));
addWisp('#2040ff', 0.018);
addWisp('#601080', 0.012);

const planetList = [
  { r: 28, p: [280, -130, -300], c1: '#8b2200', c2: '#c44a1a', c3: '#6b1800', a: '#ff4422' },
  { r: 18, p: [-320, 160, -450], c1: '#0d4a5c', c2: '#1a7a8c', c3: '#0a3040', a: '#00d4ff' },
  { r: 38, p: [420, 60, -550], c1: '#3d1a5c', c2: '#6b3a8c', c3: '#2a1040', a: '#a080ff', ring: '#5a3070' }
];

const pUniforms = [];
planetList.forEach(d => {
  const u = { time: { value: 0 } };
  pUniforms.push(u);
  const pGeo = new THREE.SphereGeometry(d.r, 48, 48);
  const pMat = new THREE.ShaderMaterial({
    uniforms: { ...u, c1: { value: new THREE.Color(d.c1) }, c2: { value: new THREE.Color(d.c2) }, c3: { value: new THREE.Color(d.c3) } },
    vertexShader: planetVert, fragmentShader: planetFrag
  });
  const mesh = new THREE.Mesh(pGeo, pMat);
  mesh.position.set(d.p[0], d.p[1], d.p[2]);
  scene.add(mesh);

  const aMat = new THREE.ShaderMaterial({
    uniforms: { atmCol: { value: new THREE.Color(d.a) } },
    vertexShader: planetVert, fragmentShader: atmFrag,
    transparent: true, depthWrite: false, blending: THREE.AdditiveBlending
  });
  const atm = new THREE.Mesh(new THREE.SphereGeometry(d.r * 1.12, 32, 32), aMat);
  atm.position.set(d.p[0], d.p[1], d.p[2]);
  scene.add(atm);

  if (d.ring) {
    const rGeo = new THREE.RingGeometry(d.r * 1.4, d.r * 2.2, 64);
    const rMat = new THREE.MeshBasicMaterial({ color: d.ring, side: THREE.DoubleSide, transparent: true, opacity: 0.35, depthWrite: false });
    const ring = new THREE.Mesh(rGeo, rMat);
    ring.position.set(d.p[0], d.p[1], d.p[2]);
    ring.rotation.x = Math.PI * 0.35;
    scene.add(ring);
  }
});

const scroll = { p: 0 };
ScrollTrigger.create({
  trigger: document.body, start: 'top top', end: 'bottom bottom',
  onUpdate: self => { scroll.p = self.progress; }
});

const clock = new THREE.Clock();
gsap.ticker.add(() => {
  const t = clock.getElapsedTime();
  uniforms.uTime.value = t;
  pUniforms.forEach(u => u.time.value = t);
  camera.position.z += (400 - scroll.p * 300 - camera.position.z) * 0.08;
  camera.position.y += (scroll.p * -60 - camera.position.y) * 0.05;
  scene.children.forEach(c => {
    if (c instanceof THREE.Mesh && c.geometry instanceof THREE.SphereGeometry) c.rotation.y = t * 0.04;
  });
  renderer.render(scene, camera);
});

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});
</script>
