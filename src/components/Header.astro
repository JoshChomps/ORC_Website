---
import { Image } from 'astro:assets';
import logoSvg from '../assets/logo.svg';
---

<header class="top-bar">
    <div class="top-bar_container">
        <a href="/" class="logo">
            <img src={logoSvg.src} alt="Logo" style="width: 100px; height: 50px; object-fit:cover; padding:0px; margin:0px">
        </a>

        <button class="hamburger-icon" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <nav class="navigation" id="navMenu">
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/gallery">Gallery</a></li>
                <li><a href="/404">Projects</a></li>
                <li><a href="/members">Members</a></li>
                <li><a href="/404">Donate</a></li>
                <li><a href="/sponsors">Sponsors</a></li>
            </ul>
        </nav>
    </div>
</header>

<script>
    function initMenu() {
        const btn = document.getElementById('hamburger');
        const menu = document.getElementById('navMenu');

        if (btn && menu) {
            btn.addEventListener('click', () => {
                btn.classList.toggle('active');
                menu.classList.toggle('active');
            });
        }

        document.querySelectorAll('.navigation a').forEach(a => {
            a.addEventListener('click', () => {
                btn?.classList.remove('active');
                menu?.classList.remove('active');
            });
        });

        document.addEventListener('click', e => {
            if (btn && menu && !btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
                btn.classList.remove('active');
                menu.classList.remove('active');
            }
        });
    }
    initMenu();
</script>

<style>

    .hamburger-icon {
        background: none;
        border: none;
        padding: 0;
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
    }
    
    @media (max-width: 1024px) {
        .hamburger-icon {
            display: flex;
        }
    }
</style>
