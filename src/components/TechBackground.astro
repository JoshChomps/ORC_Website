---
/**
 * TechBackground.astro
 * A sophisticated 'Mission Control' HUD background with grid lines, 
 * technical rover schematics, and a scanning sensor sweep.
 */
---
<div class="tech-background-container">
    <div class="grid-overlay"></div>
    <div class="schematic-overlay">
        <!-- SVG Rover Schematic (Simplified technical lines) -->
        <svg viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg" class="rover-blueprint">
            <path d="M100 400H700M150 400L200 250H600L650 400M250 250V200H550V250M300 200L400 100L500 200M180 430C180 446.569 166.569 460 150 460C133.431 460 120 446.569 120 430C120 413.431 133.431 400 150 400C166.569 400 180 413.431 180 430ZM680 430C680 446.569 666.569 460 650 460C633.431 460 620 446.569 620 430C620 413.431 633.431 400 650 400C666.569 400 680 413.431 680 430ZM430 430C430 446.569 416.569 460 400 460C383.431 460 370 446.569 370 430C370 413.431 383.431 400 400 400C416.569 400 430 413.431 430 430Z" stroke="currentColor" stroke-width="1" stroke-dasharray="4 4" />
        </svg>
    </div>
    <div class="scan-line"></div>
    <div class="vignette"></div>
</div>

<style is:global>
    .tech-background-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -2;
        background-color: #020408;
        overflow: hidden;
    }

    /* Engineering Grid */
    .grid-overlay {
        position: absolute;
        width: 200%;
        height: 200%;
        top: -50%;
        left: -50%;
        background-image: 
            linear-gradient(rgba(0, 209, 255, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 209, 255, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
        transform: perspective(500px) rotateX(20deg);
        opacity: 0.5;
    }

    /* Drifting Blueprint */
    .schematic-overlay {
        position: absolute;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(0, 209, 255, 0.08);
        z-index: -1;
    }

    .rover-blueprint {
        width: 80%;
        max-width: 1200px;
        animation: blueprint-drift 40s infinite alternate ease-in-out;
    }

    @keyframes blueprint-drift {
        0% { transform: scale(1.1) translate(-20px, -20px) rotate(-1deg); }
        100% { transform: scale(1.2) translate(20px, 20px) rotate(1deg); }
    }

    /* Sensor Sweep Line */
    .scan-line {
        position: absolute;
        top: -100%;
        left: 0;
        width: 100%;
        height: 100px;
        background: linear-gradient(
            to bottom,
            transparent 0%,
            rgba(0, 209, 255, 0.1) 50%,
            transparent 100%
        );
        z-index: 10;
        animation: scan-sweep 10s infinite linear;
    }

    @keyframes scan-sweep {
        0% { top: -20%; }
        100% { top: 120%; }
    }

    /* Depth Vignette */
    .vignette {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at center, transparent 0%, rgba(2, 4, 8, 0.8) 100%);
    }
</style>
