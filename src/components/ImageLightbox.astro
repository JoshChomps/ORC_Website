---
---
<div id="lightbox" class="lightbox" aria-hidden="true">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-container">
        <button class="lightbox-close" aria-label="Close lightbox">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <div class="lightbox-image-wrapper">
            <img id="lightbox-img" src="" alt="" draggable="false" />
        </div>
        <div class="lightbox-controls">
            <span class="lightbox-hint">Click image to toggle zoom</span>
        </div>
    </div>
</div>

<style is:global>
    [data-zoomable] {
        cursor: zoom-in;
    }

    .lightbox {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;
        display: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        overflow: hidden;
    }

    .lightbox.active {
        display: block;
        opacity: 1;
    }

    .lightbox-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(10px);
    }

    .lightbox-container {
        position: relative;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lightbox-close {
        position: absolute;
        top: 30px;
        right: 30px;
        z-index: 10;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 10px;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .lightbox-close:hover {
        background: var(--color-nebula);
        transform: rotate(90deg);
    }

    .lightbox-image-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    #lightbox-img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: center;
        cursor: zoom-in;
    }

    #lightbox-img.zoomed {
        max-width: none;
        max-height: none;
        cursor: zoom-out;
        transform: scale(2);
    }

    .lightbox-controls {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        pointer-events: none;
    }

    .lightbox-hint {
        background: rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 8px 16px;
        border-radius: 20px;
        font-family: var(--font-header);
        font-size: 0.8rem;
        color: white;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>

<script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = lightbox?.querySelector('.lightbox-close');
    const overlay = lightbox?.querySelector('.lightbox-overlay');

    let isZoomed = false;

    function openLightbox(src: string) {
        if (!lightbox || !lightboxImg) return;
        
        lightboxImg.src = src;
        lightbox.style.display = 'block';
        setTimeout(() => {
            lightbox.classList.add('active');
        }, 10);
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        if (!lightbox) return;
        lightbox.classList.remove('active');
        setTimeout(() => {
            lightbox.style.display = 'none';
            if (lightboxImg) {
                lightboxImg.classList.remove('zoomed');
                lightboxImg.style.transform = '';
            }
            isZoomed = false;
        }, 300);
        document.body.style.overflow = '';
    }

    function toggleZoom(e: MouseEvent) {
        if (!lightboxImg) return;
        
        isZoomed = !isZoomed;
        
        if (isZoomed) {
            lightboxImg.classList.add('zoomed');
            // Center the zoom on click position if possible, but for now simple 2x
        } else {
            lightboxImg.classList.remove('zoomed');
            lightboxImg.style.transform = '';
        }
    }

    // Initialize listeners
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const zoomable = target.closest('[data-zoomable]');
        
        if (zoomable) {
            const img = zoomable.querySelector('img') || zoomable as HTMLImageElement;
            const src = img.getAttribute('src');
            if (src) openLightbox(src);
        }
    });

    closeBtn?.addEventListener('click', closeLightbox);
    overlay?.addEventListener('click', closeLightbox);
    lightboxImg?.addEventListener('click', toggleZoom);

    // Keyboard support
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });

    // Panning logic when zoomed
    let isDragging = false;
    let startX: number, startY: number;
    let translateX = 0, translateY = 0;

    lightboxImg?.addEventListener('mousedown', (e) => {
        if (!isZoomed) return;
        isDragging = true;
        startX = e.clientX - translateX;
        startY = e.clientY - translateY;
        lightboxImg.style.cursor = 'grabbing';
    });

    window.addEventListener('mousemove', (e) => {
        if (!isDragging || !isZoomed || !lightboxImg) return;
        translateX = e.clientX - startX;
        translateY = e.clientY - startY;
        lightboxImg.style.transform = `scale(2) translate(${translateX / 2}px, ${translateY / 2}px)`;
    });

    window.addEventListener('mouseup', () => {
        isDragging = false;
        if (lightboxImg) {
            lightboxImg.style.cursor = isZoomed ? 'zoom-out' : 'zoom-in';
        }
    });
</script>
